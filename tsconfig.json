'use client'
import { useState } from 'react'
import { useMarketStore } from '@/store/useMarketStore'
import { DEFAULT_THRESHOLDS } from '@/types'

export function SettingsPanel() {
  const [open, setOpen] = useState(false)
  const { thresholds, setThresholds } = useMarketStore()

  return (
    <div style={{ background: 'var(--bg-card)', border: '1px solid var(--bg-border)', borderRadius: 12, overflow: 'hidden' }}>
      <button onClick={() => setOpen(v => !v)} style={{ width: '100%', display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '12px 20px', background: 'none', border: 'none', cursor: 'pointer', color: 'var(--text-secondary)' }}>
        <span style={{ fontSize: 11, fontFamily: 'monospace', textTransform: 'uppercase', letterSpacing: '0.1em' }}>⚙ Paramètres</span>
        <span style={{ fontSize: 12 }}>{open ? '▲' : '▼'}</span>
      </button>

      {open && (
        <div style={{ padding: '0 20px 20px', borderTop: '1px solid var(--bg-border)', display: 'flex', flexDirection: 'column', gap: 16, paddingTop: 16 }}>
          {/* Mode toggle */}
          <div>
            <div style={{ fontSize: 11, color: 'var(--text-muted)', fontFamily: 'monospace', marginBottom: 8 }}>Mode de détection</div>
            <div style={{ display: 'flex', gap: 8 }}>
              {(['aggressive', 'strict'] as const).map(m => (
                <button key={m} onClick={() => setThresholds({ mode: m })} style={{ flex: 1, padding: '6px 12px', borderRadius: 6, border: `1px solid ${thresholds.mode === m ? 'var(--accent-green)' : 'var(--bg-border)'}`, background: thresholds.mode === m ? 'rgba(0,212,168,0.1)' : 'var(--bg-secondary)', color: thresholds.mode === m ? 'var(--accent-green)' : 'var(--text-muted)', fontSize: 12, fontFamily: 'monospace', cursor: 'pointer' }}>
                  {m === 'aggressive' ? '⚡ Agressif' : '🔒 Strict'}
                </button>
              ))}
            </div>
          </div>

          {/* Sliders */}
          {[
            { label: 'OI Build-Up seuil (%)', key: 'oiBuildUpThresholdPct' as const, min: 0.1, max: 2, step: 0.1 },
            { label: 'Impulsion min (%)',      key: 'impulseMinPct' as const,          min: 0.1, max: 2, step: 0.1 },
            { label: 'Consolidation max (%)',  key: 'consolidationMaxPct' as const,    min: 0.05, max: 0.5, step: 0.05 },
            { label: 'Score signal fort',      key: 'minScoreStrong' as const,         min: 3, max: 12, step: 1 },
            { label: 'Score signal moyen',     key: 'minScoreMedium' as const,         min: 2, max: 10, step: 1 },
          ].map(({ label, key, min, max, step }) => (
            <div key={key}>
              <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 11, fontFamily: 'monospace', marginBottom: 6 }}>
                <span style={{ color: 'var(--text-secondary)' }}>{label}</span>
                <span style={{ color: 'var(--accent-yellow)', fontWeight: 700 }}>{thresholds[key]}</span>
              </div>
              <input type="range" min={min} max={max} step={step} value={thresholds[key]} onChange={e => setThresholds({ [key]: parseFloat(e.target.value) })}
                style={{ width: '100%', accentColor: 'var(--accent-green)', cursor: 'pointer' }} />
            </div>
          ))}

          <button onClick={() => setThresholds({ ...DEFAULT_THRESHOLDS })} style={{ padding: '6px 12px', borderRadius: 6, border: '1px solid var(--bg-border)', background: 'var(--bg-secondary)', color: 'var(--text-muted)', fontSize: 12, fontFamily: 'monospace', cursor: 'pointer', textAlign: 'left' }}>
            ↺ Reset par défaut
          </button>
        </div>
      )}
    </div>
  )
}
